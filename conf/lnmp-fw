#!/usr/bin/env bash

# Universal firewall port manager
# RHEL/Rocky/Alma/CentOS/Fedora: firewalld/firewall-cmd
# Debian/Ubuntu: ufw
# Firewall backend support here is independent from the main LNMP installer OS allowlist.

set -euo pipefail

# Recognize --force in any position (not bound to $4) so e.g. `deny 22 --force`
# works without requiring an explicit proto.
FORCE=""
positional=()
for arg in "$@"; do
    if [ "$arg" = "--force" ]; then
        FORCE="--force"
    else
        positional+=("$arg")
    fi
done

ACTION="${positional[0]:-}"
PORT="${positional[1]:-}"
PROTO="${positional[2]:-tcp}"

# Echo_Red/Echo_Yellow write to stderr and Echo_Green/Echo_Blue write to
# stdout, so each stream's coloring (including its reset code) must be gated
# on whether *that* stream is a terminal -- otherwise redirecting just one
# stream still leaks raw ANSI codes (or stray resets) into a log/pipe.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    OUT_GREEN='\033[0;32m'
    OUT_BLUE='\033[0;34m'
    OUT_NC='\033[0m'
else
    OUT_GREEN=''
    OUT_BLUE=''
    OUT_NC=''
fi

if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
    ERR_RED='\033[0;31m'
    ERR_YELLOW='\033[1;33m'
    ERR_NC='\033[0m'
else
    ERR_RED=''
    ERR_YELLOW=''
    ERR_NC=''
fi

Echo_Red()    { echo -e "${ERR_RED}$*${ERR_NC}" >&2; }
Echo_Green()  { echo -e "${OUT_GREEN}$*${OUT_NC}"; }
Echo_Yellow() { echo -e "${ERR_YELLOW}$*${ERR_NC}" >&2; }
Echo_Blue()   { echo -e "${OUT_BLUE}$*${OUT_NC}"; }

usage() {
    cat <<EOF
Usage:
  $0 allow <port> [tcp|udp|all]
  $0 deny <port> [tcp|udp|all]
  $0 delete-allow <port> [tcp|udp|all]
  $0 delete-deny <port> [tcp|udp|all]
  $0 deny <ssh-port> tcp --force
  $0 delete-allow <ssh-port> tcp --force
  $0 status
  $0 reload

Examples:
  $0 allow 80 tcp
  $0 allow 443 tcp
  $0 allow 53 udp
  $0 allow 53 all
  $0 deny 3306 tcp
  $0 delete-allow 8080 tcp
  $0 status

Notes:
  - On RHEL family, this script uses firewall-cmd.
  - On Debian/Ubuntu, this script uses ufw.
  - This firewall helper supports some distros independently from LNMP installer support.
  - "deny" removes any existing allow rule first, then adds an explicit deny/drop rule.
  - Denying SSH or deleting an SSH allow rule requires interactive confirmation or --force.
EOF
}

need_root() {
    if [ "$(id -u)" -ne 0 ]; then
        Echo_Red "Error: please run as root."
        exit 1
    fi
}

detect_backend() {
    if [ ! -f /etc/os-release ]; then
        Echo_Red "Error: /etc/os-release not found. Cannot detect OS."
        exit 1
    fi

    # shellcheck disable=SC1091
    . /etc/os-release

    local id="${ID:-}"
    local id_like="${ID_LIKE:-}"

    case "${id} ${id_like}" in
        *rhel*|*fedora*|*centos*|*rocky*|*almalinux*)
            echo "firewalld"
            ;;
        *debian*|*ubuntu*)
            echo "ufw"
            ;;
        *)
            Echo_Red "Unsupported OS: ID=${id}, ID_LIKE=${id_like}"
            exit 1
            ;;
    esac
}

check_port() {
    local port="$1"

    if ! echo "$port" | grep -Eq '^[0-9]+$'; then
        Echo_Red "Error: invalid port: $port"
        exit 1
    fi

    if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        Echo_Red "Error: port must be between 1 and 65535."
        exit 1
    fi
}

check_proto() {
    local proto="$1"

    case "$proto" in
        tcp|udp|all)
            ;;
        *)
            Echo_Red "Error: protocol must be tcp, udp, or all."
            exit 1
            ;;
    esac
}

ssh_ports() {
    local config

    {
        # Always include 22 even if sshd_config says otherwise -- conservative
        # by design: a false positive just adds a confirmation prompt, while a
        # false negative could let an admin lock themselves out of SSH.
        printf "%s\n" "22"

        if [[ -n "${SSH_CONNECTION:-}" ]]; then
            printf "%s\n" "$SSH_CONNECTION" | awk '{print $4}'
        fi

        for config in /etc/ssh/sshd_config /etc/ssh/sshd_config.d/*.conf; do
            [[ -r "$config" ]] || continue
            awk '
                /^[[:space:]]*#/ { next }
                /^[[:space:]]*Port[[:space:]]+[0-9]+/ { print $2 }
            ' "$config"
        done
    } | awk '/^[0-9]+$/ && $1 >= 1 && $1 <= 65535 && !seen[$1]++'
}

is_ssh_port() {
    local port="$1"
    local ssh_port

    while read -r ssh_port; do
        if [[ "$port" == "$ssh_port" ]]; then
            return 0
        fi
    done < <(ssh_ports)

    return 1
}

confirm_ssh_risk() {
    local action="$1"
    local port="$2"
    local proto="$3"
    local answer

    case "$action" in
        deny|delete-allow)
            ;;
        *)
            return 0
            ;;
    esac

    if [[ "$proto" != "tcp" && "$proto" != "all" ]]; then
        return 0
    fi

    if ! is_ssh_port "$port"; then
        return 0
    fi

    if [[ "$FORCE" == "--force" || "${LNMP_FW_FORCE:-0}" == "1" ]]; then
        return 0
    fi

    Echo_Yellow "Warning: this may block SSH access on port ${port}/${proto}."
    Echo_Yellow "Current SSH ports are detected from SSH_CONNECTION and sshd_config."

    if [[ ! -t 0 ]]; then
        Echo_Red "Error: refusing SSH-sensitive firewall change without --force."
        exit 1
    fi

    read -r -p "Type YES to continue: " answer
    if [[ "$answer" != "YES" ]]; then
        Echo_Red "Aborted."
        exit 1
    fi
}

proto_list() {
    local proto="$1"

    if [ "$proto" = "all" ]; then
        echo "tcp udp"
    else
        echo "$proto"
    fi
}

firewalld_remove_deny_rules() {
    local port="$1"
    local proto="$2"
    local family
    local target

    for family in ipv4 ipv6; do
        for target in drop reject; do
            firewalld_remove_rich_rule_if_present "rule family='${family}' port port='${port}' protocol='${proto}' ${target}"
        done
    done
}

firewalld_remove_port_if_present() {
    local port_proto="$1"
    local output

    if output=$(firewall-cmd --permanent --remove-port="$port_proto" 2>&1); then
        return 0
    fi

    if [[ "$output" == *"NOT_ENABLED"* || "$output" == *"not enabled"* ]]; then
        return 0
    fi

    Echo_Red "Error: failed to delete firewalld allow rule for $port_proto."
    [[ -n "$output" ]] && Echo_Red "$output"
    return 1
}

firewalld_remove_rich_rule_if_present() {
    local rule="$1"
    local output

    if output=$(firewall-cmd --permanent --remove-rich-rule="$rule" 2>&1); then
        return 0
    fi

    if [[ "$output" == *"NOT_ENABLED"* || "$output" == *"not enabled"* ]]; then
        return 0
    fi

    Echo_Red "Error: failed to delete firewalld rich rule: $rule"
    [[ -n "$output" ]] && Echo_Red "$output"
    return 1
}

firewalld_add_drop_rules() {
    local port="$1"
    local proto="$2"
    local family
    local rule
    local added_rules=()
    local ipv6_available=1

    [ -e /proc/net/if_inet6 ] || ipv6_available=0

    for family in ipv4 ipv6; do
        rule="rule family='${family}' port port='${port}' protocol='${proto}' drop"
        if firewall-cmd --permanent --add-rich-rule="$rule" >/dev/null; then
            added_rules+=("$rule")
        elif [ "$family" = "ipv6" ] && [ "$ipv6_available" -eq 0 ]; then
            Echo_Yellow "Warning: skipping IPv6 drop rule for ${port}/${proto} -- IPv6 appears disabled on this host."
        else
            for rule in "${added_rules[@]}"; do
                firewall-cmd --permanent --remove-rich-rule="$rule" >/dev/null 2>&1 || true
            done
            return 1
        fi
    done
}

FIREWALLD_LOCK_FILE="/var/run/lnmp-fw-firewalld.lock"

# Serializes our --permanent edit + --reload sequences so two concurrent
# invocations can't interleave and leave permanent/runtime config diverged.
acquire_firewalld_lock() {
    if ! command -v flock >/dev/null 2>&1; then
        Echo_Yellow "Warning: 'flock' not found (install util-linux for it); proceeding without a concurrency lock."
        Echo_Yellow "Avoid running lnmp-fw concurrently while this is missing."
        return 0
    fi

    exec 9>"$FIREWALLD_LOCK_FILE" || {
        Echo_Red "Error: cannot open lock file ${FIREWALLD_LOCK_FILE}."
        exit 1
    }

    if ! flock -w 10 9; then
        Echo_Red "Error: timed out waiting for another lnmp-fw instance to finish modifying firewalld."
        exit 1
    fi
}

check_firewalld() {
    if ! command -v firewall-cmd >/dev/null 2>&1; then
        Echo_Red "Error: firewall-cmd not found. Please install firewalld first."
        exit 1
    fi

    if ! firewall-cmd --state >/dev/null 2>&1; then
        Echo_Yellow "Warning: firewalld is not running."
        Echo_Yellow "Try: systemctl enable --now firewalld"
        exit 1
    fi
}

check_ufw() {
    local require_active="${1:-0}"

    if ! command -v ufw >/dev/null 2>&1; then
        Echo_Red "Error: ufw not found. Please install ufw first."
        Echo_Yellow "Debian/Ubuntu:"
        Echo_Yellow "  apt update && apt install -y ufw"
        exit 1
    fi

    if ! ufw status | grep -qi "Status: active"; then
        if [ "$require_active" -eq 1 ]; then
            Echo_Red "Error: ufw is installed but not active."
            Echo_Yellow "Firewall rule changes will not take effect until ufw is enabled."
            Echo_Yellow "Before enabling ufw on SSH servers, make sure SSH is allowed:"
            Echo_Yellow "  ufw allow 22/tcp"
            Echo_Yellow "  ufw enable"
            exit 1
        fi

        Echo_Yellow "Warning: ufw is installed but not active."
        Echo_Yellow "Before enabling ufw on SSH servers, make sure SSH is allowed:"
        Echo_Yellow "  ufw allow 22/tcp"
        Echo_Yellow "  ufw enable"
    fi
}

firewalld_resync_after_failure() {
    local what="$1"

    Echo_Red "Error: ${what}"
    Echo_Yellow "The permanent firewalld configuration may now differ from the running configuration."
    if firewall-cmd --reload >/dev/null 2>&1; then
        Echo_Yellow "Reloaded firewalld to resync; verify with 'firewall-cmd --list-all' and re-run if needed."
    else
        Echo_Yellow "Reload also failed -- run 'firewall-cmd --reload' manually, then 'firewall-cmd --list-all' to inspect."
    fi
    exit 1
}

firewalld_allow() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        firewall-cmd --permanent --add-port="${port}/${p}" >/dev/null \
            || firewalld_resync_after_failure "failed to add firewalld allow rule for ${port}/${p}."

        # Remove possible previous deny rich rules.
        firewalld_remove_deny_rules "$port" "$p" \
            || firewalld_resync_after_failure "failed to remove conflicting deny rules for ${port}/${p}."
    done

    firewall-cmd --reload >/dev/null \
        || firewalld_resync_after_failure "reload failed after staging ${port}/${proto} allow changes."
    for p in $(proto_list "$proto"); do
        Echo_Green "Allowed ${port}/${p} with firewalld."
    done
}

firewalld_warn_service_allow() {
    local port="$1"
    local proto="$2"
    local svc

    for svc in $(firewall-cmd --list-services 2>/dev/null); do
        if firewall-cmd --info-service="$svc" 2>/dev/null | grep -qE "ports:.*\b${port}/${proto}\b"; then
            Echo_Yellow "Warning: service '${svc}' is allowed in this zone and lists ${port}/${proto} among its ports."
            Echo_Yellow "  'deny' only removes port-based allow rules, not service allows -- ${port}/${proto} may remain reachable."
            Echo_Yellow "  To also close it: firewall-cmd --permanent --remove-service=${svc} && firewall-cmd --reload"
        fi
    done
}

firewalld_deny() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        # Add explicit drop rule for IPv4 and IPv6.
        firewalld_add_drop_rules "$port" "$p" \
            || firewalld_resync_after_failure "failed to add firewalld drop rule for ${port}/${p}."

        # Remove allow after the full deny rule set has been staged.
        firewalld_remove_port_if_present "${port}/${p}" \
            || firewalld_resync_after_failure "failed to remove allow rule for ${port}/${p}."

        # A service allow (e.g. --add-service=http/ssh) is not removed above
        # and can still leave the port reachable -- warn so the user can check.
        firewalld_warn_service_allow "$port" "$p"
    done

    firewall-cmd --reload >/dev/null \
        || firewalld_resync_after_failure "reload failed after staging ${port}/${proto} deny changes."
    for p in $(proto_list "$proto"); do
        Echo_Green "Denied ${port}/${p} with firewalld."
    done
}

firewalld_delete_allow() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        firewalld_remove_port_if_present "${port}/${p}" \
            || firewalld_resync_after_failure "failed to delete allow rule for ${port}/${p}."
    done

    firewall-cmd --reload >/dev/null \
        || firewalld_resync_after_failure "reload failed after deleting allow rule for ${port}/${proto}."
    for p in $(proto_list "$proto"); do
        Echo_Green "Deleted or confirmed absent allow rule for ${port}/${p} from firewalld."
    done
}

firewalld_delete_deny() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        firewalld_remove_deny_rules "$port" "$p" \
            || firewalld_resync_after_failure "failed to delete deny rule for ${port}/${p}."
    done

    firewall-cmd --reload >/dev/null \
        || firewalld_resync_after_failure "reload failed after deleting deny rule for ${port}/${proto}."
    for p in $(proto_list "$proto"); do
        Echo_Green "Deleted or confirmed absent deny rule for ${port}/${p} from firewalld."
    done
}

ufw_allow() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        ufw allow "${port}/${p}" >/dev/null
        Echo_Green "Allowed ${port}/${p} with ufw."
    done
}

ufw_warn_app_allow() {
    local port="$1"
    local proto="$2"
    local profile spec

    while IFS= read -r profile; do
        [ -n "$profile" ] || continue
        # Must not abort ufw_deny under set -e/pipefail: this is advisory only.
        spec=$(ufw app info "$profile" 2>/dev/null | sed -n '/^Ports:/,$p' | tail -n +2) || spec=""
        [ -n "$spec" ] || continue
        if echo "$spec" | grep -qE "(^|[^0-9])${port}([^0-9]|$)" && echo "$spec" | grep -qi "$proto" \
            && ufw status | grep -qE "^${profile}([[:space:]]|\().*ALLOW"; then
            Echo_Yellow "Warning: app profile '${profile}' is allowed and may also cover ${port}/${proto}."
            Echo_Yellow "  'deny' only removes port-based allow rules, not named app profile allows -- ${port}/${proto} may remain reachable."
            Echo_Yellow "  Check with: ufw app info '${profile}'   and remove if needed: ufw delete allow '${profile}'"
        fi
    done < <(ufw app list 2>/dev/null | awk 'NR>1 { gsub(/^[ \t]+/, ""); if (length($0)) print }')
}

ufw_deny() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        # Remove possible allow rule first.
        ufw_delete_rule_if_present allow "${port}/${p}"

        # A named app/profile allow (e.g. "OpenSSH", "Nginx Full") is not
        # removed above and can still leave the port reachable -- warn.
        ufw_warn_app_allow "$port" "$p"

        ufw deny "${port}/${p}" >/dev/null
        Echo_Green "Denied ${port}/${p} with ufw."
    done
}

ufw_delete_rule_if_present() {
    local action="$1"
    local port_proto="$2"
    local output

    if output=$(ufw delete "$action" "$port_proto" 2>&1); then
        return 0
    fi

    if [[ "$output" == *"Could not delete non-existent rule"* ]]; then
        return 0
    fi

    Echo_Red "Error: failed to delete ufw $action rule for $port_proto."
    [[ -n "$output" ]] && Echo_Red "$output"
    return 1
}

ufw_delete_allow() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        ufw_delete_rule_if_present allow "${port}/${p}"
        Echo_Green "Deleted or confirmed absent allow rule for ${port}/${p} from ufw."
    done
}

ufw_delete_deny() {
    local port="$1"
    local proto="$2"
    local p

    for p in $(proto_list "$proto"); do
        ufw_delete_rule_if_present deny "${port}/${p}"
        Echo_Green "Deleted or confirmed absent deny rule for ${port}/${p} from ufw."
    done
}

show_firewalld_active_zone_rules() {
    local active_zones
    local zone

    active_zones=$(firewall-cmd --get-active-zones)
    if [[ -z "$active_zones" ]]; then
        Echo_Yellow "No active firewalld zones reported."
        return 0
    fi

    printf "%s\n" "$active_zones" | awk 'NF == 1 { print $1 }' | while read -r zone; do
        [[ -n "$zone" ]] || continue
        echo
        Echo_Blue "Rules for active zone: $zone"
        firewall-cmd --zone="$zone" --list-all || true
    done
}

show_status() {
    local backend="$1"

    case "$backend" in
        firewalld)
            check_firewalld
            Echo_Blue "firewalld state:"
            firewall-cmd --state || true
            echo
            Echo_Blue "Default zone:"
            firewall-cmd --get-default-zone || true
            echo
            Echo_Blue "Active zones:"
            firewall-cmd --get-active-zones || true
            echo
            Echo_Blue "Default zone rules:"
            firewall-cmd --list-all || true
            show_firewalld_active_zone_rules
            ;;
        ufw)
            check_ufw
            Echo_Blue "ufw status:"
            ufw status verbose || true
            ;;
    esac
}

reload_firewall() {
    local backend="$1"

    case "$backend" in
        firewalld)
            check_firewalld
            firewall-cmd --reload >/dev/null
            Echo_Green "firewalld reloaded."
            ;;
        ufw)
            check_ufw 1
            ufw reload >/dev/null
            Echo_Green "ufw reloaded."
            ;;
    esac
}

main() {
    if [ -z "$ACTION" ]; then
        usage
        exit 1
    fi

    case "$ACTION" in
        allow|deny|delete-allow|delete-deny|status|reload)
            ;;
        *)
            Echo_Red "Error: unknown action '${ACTION}'."
            usage
            exit 1
            ;;
    esac

    need_root

    local backend
    backend="$(detect_backend)"

    case "$ACTION" in
        status)
            show_status "$backend"
            exit 0
            ;;
        reload)
            reload_firewall "$backend"
            exit 0
            ;;
    esac

    if [ -z "$PORT" ]; then
        usage
        exit 1
    fi

    check_port "$PORT"
    check_proto "$PROTO"
    confirm_ssh_risk "$ACTION" "$PORT" "$PROTO"

    case "$backend" in
        firewalld)
            check_firewalld
            acquire_firewalld_lock

            case "$ACTION" in
                allow)
                    firewalld_allow "$PORT" "$PROTO"
                    ;;
                deny)
                    firewalld_deny "$PORT" "$PROTO"
                    ;;
                delete-allow)
                    firewalld_delete_allow "$PORT" "$PROTO"
                    ;;
                delete-deny)
                    firewalld_delete_deny "$PORT" "$PROTO"
                    ;;
                *)
                    usage
                    exit 1
                    ;;
            esac
            ;;
        ufw)
            check_ufw 1

            case "$ACTION" in
                allow)
                    ufw_allow "$PORT" "$PROTO"
                    ;;
                deny)
                    ufw_deny "$PORT" "$PROTO"
                    ;;
                delete-allow)
                    ufw_delete_allow "$PORT" "$PROTO"
                    ;;
                delete-deny)
                    ufw_delete_deny "$PORT" "$PROTO"
                    ;;
                *)
                    usage
                    exit 1
                    ;;
            esac
            ;;
    esac
}

main "$@"
