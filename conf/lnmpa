Add_VHost_Config() {
    cat >"/usr/local/nginx/conf/vhost/${domain}.conf"<<EOF
server
    {
        listen 80;
        #listen [::]:80;
        server_name ${domain} ${moredomain};
        index index.html index.htm index.php default.html default.htm default.php;
        root  ${vhostdir};

        #error_page   404   /404.html;

        # Deny access to PHP files in specific directory
        #location ~ /(wp-content|uploads|wp-includes|images)/.*\.php$ { deny all; }

        include proxy-pass-php.conf;

        location ~ .*\.(gif|jpg|jpeg|png|bmp|swf)$
        {
            expires      30d;
        }

        location ~ .*\.(js|css)?$
        {
            expires      12h;
        }

        location ~ /.well-known {
            allow all;
        }

        location ~ /\.
        {
            deny all;
        }

        ${al}
    }
EOF

    cat >"/usr/local/apache/conf/vhost/${domain}.conf"<<EOF
<VirtualHost *:88>
ServerAdmin ${email}
php_admin_value open_basedir "${vhostdir}:/tmp/:/var/tmp/:/proc/"
DocumentRoot "${vhostdir}"
ServerName ${domain}
ErrorLog "/home/wwwlogs/${al_name}-error_log"
CustomLog "/home/wwwlogs/${al_name}-access_log" combined
<Directory "${vhostdir}">
    SetOutputFilter DEFLATE
    Options FollowSymLinks
    AllowOverride All
    Order allow,deny
    Allow from all
    DirectoryIndex index.html index.php
</Directory>
</VirtualHost>
EOF

    if [ "${access_log}" != 'y' ]; then
        sed -i 's/^ErrorLog/#ErrorLog/g' /usr/local/apache/conf/vhost/${domain}.conf
        sed -i 's/^CustomLog/#CustomLog/g' /usr/local/apache/conf/vhost/${domain}.conf
    fi

    if [ "${moredomain}" != "" ]; then
        sed -i "/ServerName/a\
    ServerAlias ${moredomain}" /usr/local/apache/conf/vhost/${domain}.conf
    fi

    if [ "${enable_ipv6}" == "y" ]; then
        sed -i 's/#listen \[::\]:80;/listen \[::\]:80;/g' /usr/local/nginx/conf/vhost/${domain}.conf
    fi

    echo "Test Nginx configure file......"
    if ! /usr/local/nginx/sbin/nginx -t; then
        Echo_Red "Nginx configure file test failed!"
        return 1
    fi
    echo "Test Apache configure file..."
    if ! /usr/local/apache/bin/apachectl configtest; then
        Echo_Red "Apache configure file test failed!"
        return 1
    fi
    echo ""
    echo "Reload Nginx......"
    /usr/local/nginx/sbin/nginx -s reload
    echo "Restart Apache..."
    systemctl restart httpd
}

Add_VHost() {
    domain=""
    while :; do
        Echo_Yellow "Please enter domain(example: www.getlnmp.com): "
        read -r domain
        if [ "${domain}" != "" ] && [[ "$domain" = "${domain%[[:space:]]*}" ]] && Validate_Domain "${domain}"; then
            if [[ -f "/usr/local/nginx/conf/vhost/${domain}.conf" || -f "/usr/local/apache/conf/vhost/${domain}.conf" ]]; then
                Echo_Red " ${domain} exists,please check!"
                exit 1
            else
                echo " Your domain: ${domain}"
            fi
            break
        else
            Echo_Red "Domain name can't be empty or contain spaces!"
        fi
    done

    Echo_Yellow "Enter more domain name(example: getlnmp.com sub.getlnmp.com): "
    read -r moredomain
    if [ "${moredomain}" != "" ]; then
        if ! Validate_Domain_List "${moredomain}"; then
            Echo_Red "More domain list contains invalid domain names!"
            exit 1
        fi
        echo " domain list: ${domain} ${moredomain}"
    fi

    vhostdir="/home/wwwroot/${domain}"
    Echo_Yellow "Please enter the directory for the domain: $domain"
    Echo_Yellow "Default directory: /home/wwwroot/${domain}: "
    read -r vhostdir
    if [ "${vhostdir}" == "" ]; then
        vhostdir="/home/wwwroot/${domain}"
    fi
    if ! Validate_VHost_Path "${vhostdir}"; then
        Echo_Red "Virtual Host Directory must be an absolute path without spaces or '..'."
        exit 1
    fi
    echo "Virtual Host Directory: ${vhostdir}"

    Echo_Yellow "Allow access log? (y/n) "
    read -r access_log
    if [[ "${access_log}" == "n" || "${access_log}" == "" ]]; then
        echo "Disable access log."
        al="access_log off;"
        al_name="${domain}"
    else
        Echo_Yellow "Enter access log filename(Default:${domain}.log): "
        read -r al_name
        if [ "${al_name}" == "" ]; then
            al_name="${domain}"
        fi
        if ! Validate_Simple_Name "${al_name}"; then
            Echo_Red "Access log filename contains invalid characters."
            exit 1
        fi
        al="access_log  /home/wwwlogs/${al_name}.log;"
        echo "You access log filename: ${al_name}.log"
    fi

    Echo_Yellow "Enable IPv6? (y/n) "
    read -r enable_ipv6
    if [[ "${enable_ipv6}" == "n" || "${enable_ipv6}" == "" ]]; then
        echo "Disabled IPv6 Support in current Virtualhost."
        enable_ipv6="n"
    else
        echo "Enabled IPv6 Support in current Virtualhost."
        enable_ipv6="y"
    fi

    email=""
    Echo_Yellow "Please enter Administrator Email Address: "
    read -r email
    if [ "${email}" == "" ]; then
        echo "Administrator Email Address will set to webmaster@example.com!"
        email='webmaster@example.com'
    else
        echo "Server Administrator Email:${email}"
    fi

    if [[ -s /usr/local/mysql/bin/mysql || -s /usr/local/mariadb/bin/mariadb ]]; then
        Echo_Yellow "Create database and MySQL user with same name (y/n) "
        read -r create_database

        if [ "${create_database}" == "y" ]; then
            Verify_DB_Password
            Add_Database_Menu
        fi
    fi

    if [ -s /usr/local/pureftpd/sbin/pure-ftpd ]; then
        Echo_Yellow "Create ftp account (y/n) "
        read -r create_ftp

        if [ "${create_ftp}" == "y" ]; then
            Add_Ftp_Menu
        fi
    fi

    Echo_Yellow "Add SSL Certificate (y/n) "
    read -r create_ssl
    if [ "${create_ssl}" == "y" ]; then
        Add_SSL_Menu
    fi

    echo ""
    echo "Press any key to start create virtul host..."
    OLDCONFIG=$(stty -g)
    stty -icanon -echo min 1 time 0
    dd count=1 2>/dev/null
    stty ${OLDCONFIG}

    echo "Create Virtul Host directory......"
    mkdir -p "${vhostdir}"
    if [ "${access_log}" == "y" ]; then
        touch "/home/wwwlogs/${al_name}.log"
        touch "/home/wwwlogs/${al_name}-access_log"
    fi
    echo "set permissions of Virtual Host directory......"
    chmod -R 755 "${vhostdir}"
    chown -R www:www "${vhostdir}"

    Add_VHost_Config || exit 1

    if [ "${create_database}" == "y" ]; then
        Add_Database
        TempMycnf_Clean
    fi

    if [ "${create_ftp}" == "y" ]; then
        Add_Ftp
    fi

    if [ "${create_ssl}" == "y" ]; then
        Add_SSL
    fi

    Echo_Green "================================================"
    echo "Virtualhost infomation:"
    echo "Your domain: ${domain}"
    echo "Home Directory: ${vhostdir}"
    if [ "${access_log}" == "n" ]; then
        echo "Enable log: no"
    else
        echo "Enable log: yes"
    fi
    if [ "${create_database}" == "y" ]; then
        echo "Database username: ${database_name}"
        echo "Database userpassword: ${mysql_password}"
        echo "Database Name: ${database_name}"
    else
        echo "Create database: no"
    fi
    if [ "${create_ftp}" == "y" ]; then
        echo "FTP account name: ${ftp_account_name}"
        echo "FTP account password: ${ftp_account_password}"
    else
        echo "Create ftp account: no"
    fi
    if [ "${create_ssl}" == "y" ]; then
        echo "Enable SSL: yes"
        if [ "${ssl_choice}" == "1" ]; then
            echo "  =>Certificate file"
        elif [ "${ssl_choice}" == "2" ]; then
            echo "  =>Let's Encrypt"
        elif [ "${ssl_choice}" == "3" ]; then
            echo "  =>BuyPass"
        elif [ "${ssl_choice}" == "4" ]; then
            echo "  =>ZeroSSL"
        fi
    fi
    if [ "${enable_ipv6}" == "y" ]; then
        echo "IPv6 Support: Enabled"
    else
        echo "IPv6 Support: Disabled"
    fi
    Echo_Green "================================================"
}

List_VHost() {
    echo "Nginx Virtualhost list:"
    ls /usr/local/nginx/conf/vhost/ | grep ".conf$" | sed 's/\.conf$//'
    echo "Apache Virtualhost list:"
    ls /usr/local/apache/conf/vhost/ | grep ".conf$" | sed 's/\.conf$//'
}

Del_VHost() {
    echo "======================================="
    echo "Current Virtualhost:"
    List_VHost
    echo "======================================="
    domain=""
    while :; do
        Echo_Yellow "Please enter domain you want to delete: "
        read -r domain
        if [ "${domain}" == "" ]; then
            Echo_Red "Domain name can't be empty."
        elif ! Validate_Domain "${domain}"; then
            Echo_Red "Domain name is invalid."
        else
            break
        fi
    done
    if [ ! -f "/usr/local/nginx/conf/vhost/${domain}.conf" ] && [ ! -f "/usr/local/apache/conf/vhost/${domain}.conf" ]; then
        echo "=========================================="
        echo "Domain: ${domain} was not exist!"
        echo "=========================================="
        exit 1
    else
        rm -f /usr/local/nginx/conf/vhost/${domain}.conf
        rm -f /usr/local/apache/conf/vhost/${domain}.conf
        echo "Test Nginx configure file......"
        /usr/local/nginx/sbin/nginx -t && /usr/local/nginx/sbin/nginx -s reload
        echo "Restart Apache..."
        /usr/local/apache/bin/apachectl configtest && systemctl restart httpd
        echo "========================================================"
        echo "Domain: ${domain} has been deleted."
        echo "Website files will not be deleted for security reasons."
        echo "You need to manually delete the website files."
        echo "========================================================"
    fi
}

Check_DB() {
    if [[ -s /usr/local/mariadb/bin/mariadb && -s /etc/my.cnf ]]; then
        MySQL_Bin="/usr/local/mariadb/bin/mariadb"
        MySQL_Ver=$(/usr/local/mariadb/bin/mariadb-config --version)
    elif [[ -s /usr/local/mysql/bin/mysql && -s /etc/my.cnf ]]; then
        MySQL_Bin="/usr/local/mysql/bin/mysql"
        MySQL_Ver=$(/usr/local/mysql/bin/mysql_config --version)
    else
        MySQL_Bin="None"
        return 1
    fi
    return 0
}

Make_TempMycnf() {
    if [ -z "${_mycnf_backup+set}" ]; then
        if [ -f ${HOME}/.my.cnf ]; then
            _mycnf_backup="$(mktemp /tmp/.lnmp_mycnf_bak.XXXXXX)"
            cp -p ${HOME}/.my.cnf "${_mycnf_backup}"
        else
            _mycnf_backup=""
        fi
    fi
    cat >${HOME}/.my.cnf<<EOF
[client]
user=root
password='$1'
EOF
    chmod 600 ${HOME}/.my.cnf
    trap 'TempMycnf_Clean' EXIT
    trap 'TempMycnf_Clean; exit 1' INT TERM HUP
}

Verify_DB_Password() {
    if ! Check_DB; then
        Echo_Red "Database is not installed or /etc/my.cnf is missing."
        exit 1
    fi
    status=1
    while [ $status -eq 1 ]; do
        Echo_Yellow "Enter current root password of Database (Password will not shown): "
        read -r -s DB_Root_Password
        echo
        Make_TempMycnf "${DB_Root_Password}"
        Do_Query ""
        status=$?
    done
    echo "OK, MySQL root password correct."
}

Do_Query() {
    echo "$1" >/tmp/.mysql.tmp
    chmod 600 /tmp/.mysql.tmp
    Check_DB || return 1
    ${MySQL_Bin} --defaults-file=${HOME}/.my.cnf </tmp/.mysql.tmp
    return $?
}

TempMycnf_Clean() {
    if [ -n "${_mycnf_backup}" ] && [ -f "${_mycnf_backup}" ]; then
        mv "${_mycnf_backup}" ${HOME}/.my.cnf
    elif [ -s ${HOME}/.my.cnf ]; then
        rm -f ${HOME}/.my.cnf
    fi
    unset _mycnf_backup
    trap - EXIT INT TERM HUP
    if [ -s /tmp/.mysql.tmp ]; then
        rm -f /tmp/.mysql.tmp
    fi
}

Enter_Database_Name() {
    while :; do
        Echo_Yellow "Enter database name: "
        read -r database_name
        if [ "${database_name}" == "" ]; then
            Echo_Red "Database Name can't be empty!"
        elif ! Validate_DB_Name "${database_name}"; then
            Echo_Red "Database Name can only contain letters, numbers, and underscores."
        else
            break
        fi
    done
}

Add_Database_Menu() {
    Enter_Database_Name
    echo "Your will create a database and MySQL user with same name: ${database_name}"
    Echo_Yellow "Please enter password for mysql user ${database_name}: "
    read -r mysql_password
    if ! Validate_DB_Password "${mysql_password}"; then
        Echo_Red "Database password cannot contain single quotes, backslashes, or newlines."
        exit 1
    fi
    echo "Your password: ${mysql_password} "
}

Add_Database() {
    cat >/tmp/.add_mysql.sql <<EOF
CREATE DATABASE IF NOT EXISTS \`${database_name}\`;
CREATE USER IF NOT EXISTS '${database_name}'@'localhost' IDENTIFIED BY '${mysql_password}';
CREATE USER IF NOT EXISTS '${database_name}'@'127.0.0.1' IDENTIFIED BY '${mysql_password}';
GRANT ALL PRIVILEGES ON \`${database_name}\`.* TO '${database_name}'@'localhost';
GRANT ALL PRIVILEGES ON \`${database_name}\`.* TO '${database_name}'@'127.0.0.1';
FLUSH PRIVILEGES;
EOF
    ${MySQL_Bin} --defaults-file=${HOME}/.my.cnf </tmp/.add_mysql.sql
    [ $? -eq 0 ] && echo "Add database Sucessfully." || echo "Add database failed!"
    rm -f /tmp/.add_mysql.sql
}

List_Database() {
    ${MySQL_Bin} --defaults-file=${HOME}/.my.cnf -e "SHOW DATABASES;"
    [ $? -eq 0 ] && echo "List all databases Sucessfully." || echo "List all databases failed!"
}

Edit_Database() {
    while :; do
        Echo_Yellow "Enter database username: "
        read -r database_username
        if [ "${database_username}" == "" ]; then
            Echo_Red "Database Username can't be empty!"
        elif ! Validate_DB_Name "${database_username}"; then
            Echo_Red "Database Username can only contain letters, numbers, and underscores."
        else
            break
        fi
    done
    while :; do
        Echo_Yellow "Enter NEW Password: "
        read -r database_username_passwd
        if [ "${database_username_passwd}" == "" ]; then
            Echo_Red "Database Password can't be empty!"
        elif ! Validate_DB_Password "${database_username_passwd}"; then
            Echo_Red "Database password cannot contain single quotes, backslashes, or newlines."
        else
            break
        fi
    done

    edit_status=0
    Do_Query "ALTER USER '${database_username}'@'127.0.0.1' IDENTIFIED BY '${database_username_passwd}';" || edit_status=1
    Do_Query "ALTER USER '${database_username}'@'localhost' IDENTIFIED BY '${database_username_passwd}';" || edit_status=1
    Do_Query "FLUSH PRIVILEGES;" || edit_status=1
    [ ${edit_status} -eq 0 ] && echo "Edit user password Sucessfully." || echo "Edit user password databases failed!"
}

Del_Database() {
    List_Database
    Enter_Database_Name
    if [[ "${database_name}" == "information_schema" || "${database_name}" == "mysql" || "${database_name}" == "performance_schema" ]]; then
        echo "MySQL System Database can't be delete!"
        exit 1
    fi
    echo "Your will delete database and MySQL user with same name: ${database_name}"
    echo "Sleep 10s, Press ctrl+c to cancel..."
    Sleep_Sec 10
    cat >/tmp/.del.mysql.sql <<EOF
DROP USER '${database_name}'@'127.0.0.1';
DROP USER '${database_name}'@'localhost';
DROP DATABASE \`${database_name}\`;
FLUSH PRIVILEGES;
EOF
    ${MySQL_Bin} --defaults-file=${HOME}/.my.cnf </tmp/.del.mysql.sql
    [ $? -eq 0 ] && echo "Delete database: ${database_name} Sucessfully." || echo "Delete database: ${database_name} failed!"
    rm -f /tmp/.del.mysql.sql
}

