            /usr/local/acme.sh/acme.sh --register-account -m ${email_address}
        fi
    else
        rm -rf /tmp/acme.sh
        git clone --depth 1 https://github.com/acmesh-official/acme.sh.git /tmp/acme.sh
        cd /tmp/acme.sh || exit 1
        ./acme.sh --install ${acme_sh_sudo} --log --home /usr/local/acme.sh -m ${email_address}
        rm -rf /tmp/acme.sh
    fi
    # set deaulft CA Server to letsencrypt
    #/usr/local/acme.sh/acme.sh --set-default-ca --server letsencrypt
    # enable auto upgrade for acme.sh
    /usr/local/acme.sh/acme.sh --upgrade --auto-upgrade --home /usr/local/acme.sh

    #create cert home
