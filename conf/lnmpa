Color_Text() {
  echo -e " \e[0;$2m$1\e[0m"
}

Echo_Red() {
  echo "$(Color_Text "$1" "31")"
}

Echo_Green() {
  echo "$(Color_Text "$1" "32")"
}

Echo_Yellow() {
  echo -n "$(Color_Text "$1" "33")"
}

Echo_Blue() {
  echo "$(Color_Text "$1" "34")"
}

Sleep_Sec() {
    seconds=$1
    while [ "${seconds}" -ge "0" ]; do
      echo -ne "\r     \r"
      echo -n ${seconds}
      seconds=$(($seconds - 1))
      sleep 1
    done
    echo -ne "\r"
}

