#!/bin/bash
export PATH=$PATH:/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin:~/bin

# Check if user is root
if [ "$(id -u)" != "0" ]; then
    echo "Error: You must be root to run this script!"
    exit 1
else
    if env | grep -q SUDO; then
        acme_sh_sudo="-f"
    fi
fi

echo "+-------------------------------------------+"
echo "|             LNMPA Manager                 |"
echo "+-------------------------------------------+"
echo "|           https://getlnmp.com             |"
echo "+-------------------------------------------+"

arg1=$1
arg2=$2

Validate_Domain() {
    local domain_name=$1
    [[ "${domain_name}" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$ ]]
}

Validate_Domain_List() {
    local domain_name
    for domain_name in $1; do
        [[ "${domain_name}" =~ ^(\*\.)?[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$ ]] || return 1
    done
}

Validate_VHost_Path() {
    local path_name=$1
    [[ "${path_name}" = /* && "${path_name}" != *".."* && "${path_name}" != *[[:space:]]* ]]
}

Validate_Readable_File() {
    local file_path=$1
    [[ "${file_path}" = /* && -f "${file_path}" && -r "${file_path}" ]]
}

Validate_Simple_Name() {
    local name_value=$1
    [[ "${name_value}" =~ ^[A-Za-z0-9_][A-Za-z0-9_.-]*$ ]]
}

Validate_DB_Name() {
    local name_value=$1
    [[ "${name_value}" =~ ^[A-Za-z0-9_]+$ ]]
}

Validate_DB_Password() {
    local password_value=$1
    [[ "${password_value}" != *"'"* && "${password_value}" != *"\\"* && "${password_value}" != *$'\n'* ]]
}

lnmpa_http_control() {
    local http_action=$1
    if [[ ! -s /etc/systemd/system/nginx.service ]] && [[ ! -s /etc/systemd/system/httpd.service ]]; then
        echo "Webserver is not installed!"
        return 0
    fi
    if [[ -s /etc/systemd/system/nginx.service ]]; then
        case "${http_action}" in
        start)
            systemctl start nginx
            ;;
        stop)

            systemctl stop nginx
            ;;
        restart)
            systemctl restart nginx
            ;;
        reload)
            systemctl reload nginx
            ;;
        status)
            systemctl --no-pager status nginx
            ;;
        *)
            echo "Incorrect Command for Nginx"
            exit 1
            ;;
        esac
    fi
    if [[ -s /etc/systemd/system/httpd.service ]]; then
        case "${http_action}" in
        start)
            systemctl start httpd
            ;;
        stop)

            systemctl stop httpd
            ;;
        restart)
            systemctl restart httpd
            ;;
        reload)
            systemctl reload httpd
            ;;
        status)
            systemctl --no-pager status httpd
            ;;
        *)
            echo "Incorrect Command for Apache"
            exit 1
            ;;
        esac
    fi
}

lnmpa_db_control() {
    local db_action=$1
    if [[ ! -s /etc/systemd/system/mysql.service && ! -s /etc/systemd/system/mariadb.service ]]; then
        echo "Database is not installed!"
        return 0
    fi

    if [[ -s /etc/systemd/system/mysql.service ]]; then
        db_server='mysql'
        case "${db_action}" in
        start)
            systemctl start ${db_server}
            ;;
        stop)

            systemctl stop ${db_server}
            ;;
        restart)
            systemctl restart ${db_server}
            ;;
        reload)
            systemctl reload ${db_server}
            ;;
        status)
            systemctl --no-pager status ${db_server}
            ;;
        *)
            echo "Incorrect Command for ${db_server}"
            exit 1
            ;;
        esac
    fi

    if [[ -s /etc/systemd/system/mariadb.service ]]; then
        db_server='mariadb'
        case "${db_action}" in
        start)
            systemctl start ${db_server}
            ;;
        stop)

            systemctl stop ${db_server}
            ;;
        restart)
            systemctl restart ${db_server}
            ;;
        reload)
            systemctl reload ${db_server}
            ;;
        status)
            systemctl --no-pager status ${db_server}
            ;;
        *)
            echo "Incorrect Command for ${db_server}"
            exit 1
            ;;
        esac
    fi
}

lnmpa_start() {
    echo "Starting LNMPA..."
    lnmpa_http_control start
    lnmpa_db_control start
}

lnmpa_stop() {
    echo "Stopping LNMPA..."
    lnmpa_http_control stop
    lnmpa_db_control stop
}

lnmpa_reload() {
    echo "Reload LNMPA..."
    lnmpa_http_control reload
    lnmpa_db_control reload
}

lnmpa_status() {
    lnmpa_http_control status
    lnmpa_db_control status
}


lnmpa_kill() {
    echo "Kill nginx,apache,mysql process..."
    killall nginx
    killall httpd
    killall mysqld mariadbd 2>/dev/null
    echo "done."
}


